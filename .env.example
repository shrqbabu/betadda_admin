# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=some_long_random_string_for_webhook_header
ADMIN_TELEGRAM_ID=123456789
ADMIN_SECRET=another_long_random_string_used_as_shared_secret

# Optional: comma-separated list of extra admin telegram ids
ADMIN_TELEGRAM_IDS=

# ─── Firebase Admin SDK ──────────────────────────────────
FIREBASE_PROJECT_ID=my-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@my-firebase-project.iam.gserviceaccount.com
# Use \n for line breaks OR paste the raw multiline key wrapped in quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ─── OpenRouter (AI) ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-app.example.com
OPENROUTER_SITE_NAME=Telegram Admin Backend

# ─── EmailJS (redeem code emails) ─────────────────────────
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=publicKeyFromEmailJsDashboard
EMAILJS_PRIVATE_KEY=privateAccessTokenForServerSideSends

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# Used by npm run set-webhook
WEBHOOK_URL=https://your-vercel-app.vercel.app/api/admin
